rules_version = '2';

// DEMO rules for SecureBank.
// Any signed-in user can read user docs (needed to look up a transfer recipient
// by email) and write balances/transactions (needed to credit the recipient).
//
// NOTE: this is intentionally permissive so client-side transfers work for the
// thesis demo. In production, money movement must NOT be writable by clients —
// it belongs in a Cloud Function / server with the client allowed read-only.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Read any profile (transfer recipient lookup by email).
      allow read: if request.auth != null;
      // Write any profile balance (sender debits self, credits recipient).
      allow write: if request.auth != null;

      match /transactions/{transactionId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
